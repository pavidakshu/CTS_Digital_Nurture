
    .header { background-color: #dd1b16; color: white; padding: 16px 24px; }
    .header h1 { font-size: 20px; }
    .main { display: flex; gap: 24px; padding: 24px; max-width: 1100px; margin: 0 auto; }
    .form-panel { width: 320px; flex-shrink: 0; }
    .list-panel { flex: 1; background: white; border-radius: 8px; border: 1px solid #eee; }
    @media (max-width: 700px) {
      .main { flex-direction: column; }
      .form-panel { width: 100%; }
    }
  