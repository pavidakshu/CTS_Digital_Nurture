
    .form-container { padding: 20px; background: white; border-radius: 8px; }
    h2 { margin-bottom: 16px; }
    .form-group { margin-bottom: 12px; }
    label { display: block; margin-bottom: 4px; font-weight: 500; }
    input, select { width: 100%; padding: 9px; border: 1px solid #ccc; border-radius: 4px; font-size: 14px; }
    .btn-submit { width: 100%; padding: 11px; background-color: #4caf50; color: white; border: none; border-radius: 4px; font-size: 15px; margin-top: 8px; cursor: pointer; }
    .btn-submit:disabled { background-color: #aaa; cursor: not-allowed; }
  